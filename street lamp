module dff(d,clock,clear,q);
input d;
input clock,clear ;
output reg q ;
wire in;


always @(posedge clock)
begin
if (clear)
q = 0;

else if(d==0)
q <= d ;



else if(d==1)
q <= d ;



end

endmodule
