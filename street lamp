module jkcounter(d,clock,clear,q,light);
input d;
input clock , clear ;
output  [1:0] q ;
output reg [2:0] light;


dff d0((~q[1]&~q[0]),clock,clear,q[0]);
dff d1((~q[1]&q[0]),clock,clear,q[1]);

always @(q)
begin
light[0] = q[1];
light[1] = q[0];
light[2] = (~q[1]&~q[0]);
end


